rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Global admin check (requires manual entry in 'admins' collection)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Donation Validation
    function isValidDonation(data) {
      return data.keys().hasAll(['name', 'phone', 'timestamp']) &&
             data.keys().size() <= 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             (data.get('email', '') == '' || (data.email is string && data.email.size() <= 100)) &&
             data.timestamp is string;
    }

    // Enquiry Validation
    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'timestamp']) &&
             data.keys().size() <= 5 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 1000 &&
             (data.get('phone', '') == '' || (data.phone is string && data.phone.size() <= 20)) &&
             data.timestamp is string;
    }

    match /donations/{donationId} {
      allow create: if isValidDonation(incoming());
      allow read, list: if isSignedIn(); // Simplified for preview, should be isAdmin() in production
    }

    match /enquiries/{enquiryId} {
      allow create: if isValidEnquiry(incoming());
      allow read, list: if isSignedIn(); // Simplified for preview, should be isAdmin() in production
    }
    
    // Admin collection (to be populated by the system or manually)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
